{
  "name": "@sanity-labs/react-table-kit",
  "version": "1.0.0",
  "private": false,
  "description": "Composable React table components and helpers for Sanity-flavored editorial UIs.",
  "keywords": [
    "react",
    "sanity",
    "sanity-labs",
    "table",
    "ui"
  ],
  "homepage": "https://github.com/sanity-labs/react-table-kit#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/react-table-kit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-labs/react-table-kit.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "format": "oxfmt package.json tsconfig.json tsconfig.build.json vitest.config.ts src __tests__",
    "format:check": "oxfmt --check package.json tsconfig.json tsconfig.build.json vitest.config.ts src __tests__",
    "lint": "oxlint src __tests__ vitest.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.0",
    "@radix-ui/react-popover": "^1.1.14",
    "@sanity/icons": "^3.7.4",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.0.0",
    "nuqs": "^2.8.9",
    "react-day-picker": "^9.7.0"
  },
  "devDependencies": {
    "@sanity/types": "^5.18.0",
    "@sanity/ui": "^3.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "styled-components": "^6.1.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@sanity/types": "^5.18.0",
    "@sanity/ui": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "styled-components": "^6.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
